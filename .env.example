# Base URL for the website (used in sitemap and robots.txt)
# Leave blank to use the default: https://www.orangejelly.co.uk
NEXT_PUBLIC_BASE_URL=

# Example for development:
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Example for staging:
# NEXT_PUBLIC_BASE_URL=https://staging.orangejelly.co.uk

# Google Tag Manager ID (Optional - for analytics)
# Get your GTM ID from https://tagmanager.google.com
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Supabase-backed lead database for newsletter signups, contact leads, and conversion events.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated Supabase Auth emails allowed to view /admin.
ADMIN_EMAILS=

# Lead-notification email (Resend). A new contact enquiry is stored in Supabase and,
# if these are set, also emails an alert. Notification is best-effort — a missing/failed
# send never blocks lead capture.
#   RESEND_API_KEY             — Resend API key (already set in Vercel)
#   CONTACT_FROM_EMAIL         — a sender on the Resend-verified sending SUBDOMAIN (REQUIRED to send).
#                                Production uses: Orange Jelly Website <noreply@auth.orangejelly.co.uk>
#                                Not an apex (@orangejelly.co.uk) address — the apex is not a verified
#                                sender, so an apex From will be rejected by Resend.
#   CONTACT_NOTIFICATION_EMAIL — where alerts go (defaults to peter@orangejelly.co.uk)
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_NOTIFICATION_EMAIL=

# Cloudflare Turnstile — bot check on availability-poll creation.
# Without these the poll create form fails closed: an unprotected create endpoint
# would let a script use our sending domain to mail strangers, which damages
# deliverability for real client mail.
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY — public, rendered in the widget
#   TURNSTILE_SECRET_KEY           — server-only, used for the siteverify call. Never commit it.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional direct PostgreSQL fallback for local/non-Supabase environments.
DATABASE_URL=

# Optional. Set to false for a local Postgres database that does not use SSL.
# Set to true if your hosted database requires SSL and the URL does not include sslmode=require.
DATABASE_SSL=
